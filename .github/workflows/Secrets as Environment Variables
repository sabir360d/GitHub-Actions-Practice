name: secrets-simple

on:
  workflow_dispatch:

jobs:
  demo:
    runs-on: ubuntu-latest

    steps:
      - name: Check and use secret
        env:
          MY_SECRET: ${{ secrets.MY_SECRET_MESSAGE }}
        run: |
          echo "Checking secret..."

          if [ -n "$MY_SECRET" ]; then
            echo "Secret is set"
          else
            echo "Secret is missing"
            exit 1
          fi

      - name: Check Docker secrets
        env:
          DOCKER_USERNAME: ${{ secrets.DOCKER_USERNAME }}
          DOCKER_TOKEN: ${{ secrets.DOCKER_TOKEN }}
        run: |
          echo "Checking Docker secrets..."

          if [ -n "$DOCKER_USERNAME" ] && [ -n "$DOCKER_TOKEN" ]; then
            echo "Docker secrets are set"
          else
            echo "Docker secrets missing"
            exit 1
          fi